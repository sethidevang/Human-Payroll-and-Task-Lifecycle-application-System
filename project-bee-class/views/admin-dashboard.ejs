<html>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
		<script src="https://unpkg.com/unlazy@0.11.3/dist/unlazy.with-hashing.iife.js" defer init></script>
		<script type="text/javascript"></script>
			
  </head>
  <body>
    <div class="flex h-screen bg-background">
    
    <div class="w-64 bg-white border-r border-zinc-200 p-4">
        <h1 class="text-2xl font-bold text-primary">HR SUITE</h1>
        <p class="text-muted-foreground">We take care of you as you take care of business</p>
        <nav class="mt-6">
            <ul>
                <li class="py-2"><a href="#" class="text-primary hover:text-primary-foreground">Dashboard</a></li>
                <li class="py-2"><a href="#" class="text-muted-foreground hover:text-muted">Add Employee</a></li>
                <li class="py-2"><a href="#" class="text-muted-foreground hover:text-muted">Attendance</a></li>
                <li class="py-2 relative group">
                    <!-- Main Report Item -->
                    <a href="#" class="text-muted-foreground hover:text-muted">Report</a>
                    <!-- Dropdown Menu -->
                    <ul class="absolute hidden mt-1 left-0 w-40 bg-white border border-gray-200 shadow-md group-hover:block">
                        <li class="py-2 px-4 hover:bg-gray-100">
                            <a href="#" class="text-muted-foreground hover:text-muted">Attendance</a>
                        </li>
                        <li class="py-2 px-4 hover:bg-gray-100">
                            <a href="#" class="text-muted-foreground hover:text-muted">Employee</a>
                        </li>
                    </ul>
                </li>
                <li class="py-2"><a href="#" class="text-muted-foreground hover:text-muted">Task</a></li>
                <li class="py-2"><a href="#" class="text-muted-foreground hover:text-muted">ID Card</a></li>
                <li class="py-2"><a href="#" class="text-muted-foreground hover:text-muted">Exit</a></li>
            </ul>
        </nav>
        
    </div>
        <div class="flex-1 p-6">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-xl font-semibold text-primary">Employee</h2>
                <div>
                    <input type="text" placeholder="Search" class="border border-zinc-300 rounded-lg p-2" />
                    <button class="bg-secondary text-secondary-foreground hover:bg-secondary/80 rounded-lg px-4 py-2 ml-2">Add Employee</button>
                    <button class="bg-zinc-300 text-zinc-700 hover:bg-zinc-400 rounded-lg px-4 py-2 ml-2">Filter</button>
                    <button class="bg-zinc-300 text-zinc-700 hover:bg-zinc-400 rounded-lg px-4 py-2 ml-2">Export</button>
                </div>
            </div>
        <main class="flex-1 p-8">
            <div class="grid grid-cols-3 gap-6">
                <!-- Employee Tracking Boxes -->
                <div class="bg-white shadow-md rounded-lg p-6">
                    <h2 class="text-xl font-semibold mb-2">Total Employees</h2>
                    <p class="text-3xl font-bold">250</p>
                </div>
                <div class="bg-white shadow-md rounded-lg p-6">
                    <h2 class="text-xl font-semibold mb-2">Employees on Leave</h2>
                    <p class="text-3xl font-bold">15</p>
                </div>
                <div class="bg-white shadow-md rounded-lg p-6">
                    <h2 class="text-xl font-semibold mb-2">Average Work Hours</h2>
                    <p class="text-3xl font-bold">8.5 hrs/day</p>
                </div>
                <div class="bg-white shadow-md rounded-lg p-6">
                    <h2 class="text-xl font-semibold mb-2">Tasks Completed</h2>
                    <p class="text-3xl font-bold">120</p>
                </div>
                <div class="bg-white shadow-md rounded-lg p-6">
                    <h2 class="text-xl font-semibold mb-2">New Employees</h2>
                    <p class="text-3xl font-bold">5</p>
                </div>
                <div class="bg-white shadow-md rounded-lg p-6">
                    <h2 class="text-xl font-semibold mb-2">Pending Approvals</h2>
                    <p class="text-3xl font-bold">8</p>
                </div>
            </div>
        </main>
        </div>
    </div>
</div>
  </body>
</html>