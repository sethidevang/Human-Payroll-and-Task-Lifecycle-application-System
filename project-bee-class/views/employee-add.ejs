<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>

    <title>Document</title>
</head>
<body>
    <div class="bg-background text-primary-foreground dark:bg-primary dark:text-primary-foreground p-4 rounded-lg shadow-md">
    <h2 class="text-lg font-semibold mb-4">Add New Employee</h2>
    <form class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <form class="grid grid-cols-1 sm:grid-cols-2 gap-4" action="/add-employee" method="post" enctype="multipart/form-data">

        <div class="mb-4">
            <label for="first-name" class="block text-sm font-medium">First Name</label>
            <input type="text" id="first-name" name="first-name" placeholder="John" class="w-full px-3 py-2 rounded-lg border focus:outline-none focus:ring focus:ring-primary" />
        </div>
        <div class="mb-4">
            <label for="last-name" class="block text-sm font-medium">Last Name</label>
            <input type="text" id="last-name" name="last-name" placeholder="Doe" class="w-full px-3 py-2 rounded-lg border focus:outline-none focus:ring focus:ring-primary" />
        </div>
        <div class="mb-4">
            <label for="email" class="block text-sm font-medium">Email</label>
            <input type="email" id="email" name="email" placeholder="john.doe@example.com" class="w-full px-3 py-2 rounded-lg border focus:outline-none focus:ring focus:ring-primary" />
        </div>
        <div class="mb-4">
            <label for="age" class="block text-sm font-medium">Age</label>
            <input type="number" id="age" name="age" placeholder="30" class="w-full px-3 py-2 rounded-lg border focus:outline-none focus:ring focus:ring-primary" />
        </div>
        <div class="mb-4">
            <label for="salary" class="block text-sm font-medium">Salary</label>
            <input type="number" id="salary" name="salary" placeholder="50000" class="w-full px-3 py-2 rounded-lg border focus:outline-none focus:ring focus:ring-primary" />
        </div>
        <div class="mb-4">
            <label for="designation" class="block text-sm font-medium">Designation</label>
            <input type="text" id="designation" name="designation" placeholder="Software Engineer" class="w-full px-3 py-2 rounded-lg border focus:outline-none focus:ring focus:ring-primary" />
        </div>
        <div class="mb-4">
            <label for="photo" class="block text-sm font-medium">Photo URL</label>
            <input type="url" id="photo" name="photo" placeholder="https://placehold.co/100x100" class="w-full px-3 py-2 rounded-lg border focus:outline-none focus:ring focus:ring-primary" />
        </div>
        <div class="mb-4">
            <label for="passport-number" class="block text-sm font-medium">Passport Number</label>
            <input type="text" id="passport-number" name="passport-number" placeholder="A12345678" class="w-full px-3 py-2 rounded-lg border focus:outline-none focus:ring focus:ring-primary" />
        </div>
        <div class="mb-4">
            <label for="nominee" class="block text-sm font-medium">Nominee</label>
            <input type="text" id="nominee" name="nominee" placeholder="Jane Doe" class="w-full px-3 py-2 rounded-lg border focus:outline-none focus:ring focus:ring-primary" />
        </div>
        <div class="mb-4">
            <label for="user-id" class="block text-sm font-medium">User ID</label>
            <input type="text" id="user-id" name="user-id" placeholder="john.doe" class="w-full px-3 py-2 rounded-lg border focus:outline-none focus:ring focus:ring-primary" />
        </div>
        <div class="mb-4 sm:col-span-2">
            <label for="address" class="block text-sm font-medium">Address</label>
            <input type="text" id="address" name="address" placeholder="123 Main St, City" class="px-3 py-2 rounded-lg border focus:outline-none focus:ring focus:ring-primary" />
        </div>
        <div class="mb-4">
            <label for="password" class="block text-sm font-medium">Password</label>
            <input type="password" id="password" name="password" placeholder="********" class="w-full px-3 py-2 rounded-lg border focus:outline-none focus:ring focus:ring-primary" />
        </div>
        <div class="mb-4">
            <label for="photo-upload" class="block text-sm font-medium">Upload Photo</label>
            <input type="file" id="photo-upload" name="photo-upload" accept="image/*" class="w-full px-3 py-2 rounded-lg border focus:outline-none focus:ring focus:ring-primary" />
        </div>
        <button type="submit" class="bg-primary text-primary-foreground py-2 px-4 rounded-lg hover:bg-primary/80 focus:outline-none focus:ring focus:ring-primary">Add Employee</button>
    </form>
</div>
</body>
</html>